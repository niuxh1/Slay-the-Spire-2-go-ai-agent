# Slay the Spire 2 AI Agent Configuration

# 你的 LLM API Key (OpenAI, DeepSeek, etc.)
LLM_API_KEY=sk-xxxx

# LLM API 基础 URL (可选)
# DeepSeek: https://api.deepseek.com/v1
# OpenAI: https://api.openai.com/v1
# Ollama: http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# 要使用的模型名称
# 例如: deepseek-chat, gpt-4o, llama3
LLM_MODEL=gpt-4o

# 游戏的 HTTP API 地址 (默认 http://127.0.0.1:8080)
GAME_API_URL=http://127.0.0.1:8080
